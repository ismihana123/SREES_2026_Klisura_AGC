\begin_layout Subsection
Primarna i sekundarna (AGC) regulacija frekvencije
\end_layout

\begin_layout Standard
Generatori označeni u XML konfiguraciji kao AGC tip dobijaju model turbinskog regulatora sa primarnom i sekundarnom petljom:
 
\begin_inset Formula 
\begin{align}
\frac{dx_{I}}{dt} & =K_{i}\,(1-\omega)\label{eq:integrator}\\[2pt]
\frac{dP_{m}}{dt} & =\frac{1}{T_{gov}}\Big(P_{ref}+K_{p}(1-\omega)+x_{I}-P_{m}\Big)\label{eq:governor}\\[2pt]
P^{lim}_{m} & =\mathrm{lim}\big(P_{m},\,P_{min},\,P_{max}\big)\label{eq:limiter}
\end{align}

\end_inset

Član 
\begin_inset Formula $K_{p}(1-\omega)$
\end_inset

 predstavlja primarnu (droop) regulaciju sa statizmom 
\begin_inset Formula $R=1/K_{p}$
\end_inset

;
 integrator 
\begin_inset Formula $x_{I}$
\end_inset

 (jednačina
\begin_inset space ~
\end_inset


\begin_inset CommandInset ref
LatexCommand ref
reference "eq:integrator"
plural "false"
caps "false"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

) je sekundarna regulacija koja eliminiše trajno odstupanje frekvencije;
 
\begin_inset Formula $T_{gov}$
\end_inset

 je vremenska konstanta turbine/governora,
 a limiter (jednačina
\begin_inset space ~
\end_inset


\begin_inset CommandInset ref
LatexCommand ref
reference "eq:limiter"
plural "false"
caps "false"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

) modeluje fizička ograničenja snage agregata.
 U jednačini njihanja AGC generatora umjesto 
\begin_inset Formula $P_{m}$
\end_inset

 figuriše ograničena vrijednost 
\begin_inset Formula $P^{lim}_{m}$
\end_inset

.
\end_layout

